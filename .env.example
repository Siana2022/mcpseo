# Contraseña que introducirás en la pantalla de autorización (elige una fuerte)
PROXY_PASSWORD=cambia-esto-por-una-contraseña-fuerte

# Secreto para firmar los JWT (access tokens y códigos de autorización).
# Genera uno con: openssl rand -hex 32
JWT_SECRET=cambia-esto-por-un-secreto-aleatorio-largo

# Tu API key real de DinoRank (la que ya tienes, nunca la expongas en el cliente)
DINORANK_API_KEY=tu-api-key-de-dinorank

# URL pública final de este proxy una vez desplegado, SIN barra final.
# La rellenas DESPUÉS del primer deploy, con la URL que te dé Vercel
# (o tu dominio propio si le pones uno).
PROXY_BASE_URL=https://tu-proyecto.vercel.app
