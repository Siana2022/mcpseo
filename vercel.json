{
  "rewrites": [
    { "source": "/.well-known/oauth-protected-resource", "destination": "/api/protected-resource" },
    { "source": "/.well-known/oauth-authorization-server", "destination": "/api/authorization-server" },
    { "source": "/register", "destination": "/api/register" },
    { "source": "/authorize", "destination": "/api/authorize" },
    { "source": "/token", "destination": "/api/token" },
    { "source": "/mcp", "destination": "/api/mcp" }
  ]
}
